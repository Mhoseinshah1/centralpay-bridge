# CentralPay Bridge configuration — placeholders only.
# Copy to .env and fill in real values. Never commit the real .env file.

ENVIRONMENT=production
LOG_LEVEL=INFO

# PostgreSQL connection (psycopg 3 driver)
DATABASE_URL=postgresql+psycopg://centralpay:CHANGE_ME_DB_PASSWORD@localhost:5432/centralpay

# Public HTTPS base URL of this bridge, used to build the CentralPay return URL
PUBLIC_BASE_URL=https://pay.example.com

# API key the Telegram bot must send in POST /api/custom-payment (generate a long random value)
INBOUND_API_KEY=CHANGE_ME_GENERATED_INBOUND_API_KEY

# Secret used to HMAC-sign callback URLs (generate a long random value)
CALLBACK_HMAC_SECRET=CHANGE_ME_GENERATED_CALLBACK_HMAC_SECRET

# CentralPay web service
CENTRALPAY_BASE_URL=https://centralapi.org/webservice/basic
CENTRALPAY_GETLINK_API_KEY=CHANGE_ME_CENTRALPAY_GETLINK_KEY
CENTRALPAY_VERIFY_API_KEY=CHANGE_ME_CENTRALPAY_VERIFY_KEY

# Numeric userId sent to CentralPay getLink and validated on verify
CENTRALPAY_USER_ID=1

# Timeout in seconds for outbound CentralPay HTTP calls
CENTRALPAY_TIMEOUT_SECONDS=15

# --- Bot notification (Phase 2) ---

# Complete bot payment endpoint, e.g. https://bot.example.com/api/payment
BOT_PAYMENT_NOTIFY_URL=https://bot.example.com/api/payment

# Token sent in the Token header (the bot /token2 value)
BOT_NOTIFY_TOKEN=CHANGE_ME_BOT_TOKEN

# safe (default): never auto-retry ambiguous deliveries; they go to manual
# review. idempotent: ONLY when the bot developer has explicitly confirmed
# duplicate order_id delivery is idempotent.
BOT_NOTIFY_RETRY_MODE=safe

# Delivery attempt limit before manual review (reason: retry_limit_reached)
BOT_NOTIFY_MAX_ATTEMPTS=6

BOT_NOTIFY_CONNECT_TIMEOUT_SECONDS=5
BOT_NOTIFY_READ_TIMEOUT_SECONDS=15

# Worker poll interval
BOT_NOTIFY_WORKER_INTERVAL_SECONDS=10

# Claims older than this are treated as an interrupted (ambiguous) attempt.
# Must exceed connect + read timeouts.
BOT_NOTIFY_CLAIM_TIMEOUT_SECONDS=120
