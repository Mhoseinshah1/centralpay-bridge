# CentralPay Bridge configuration — placeholders only.
# Copy to .env and fill in real values. Never commit the real .env file.

ENVIRONMENT=production
LOG_LEVEL=INFO

# PostgreSQL connection (psycopg 3 driver)
DATABASE_URL=postgresql+psycopg://centralpay:CHANGE_ME_DB_PASSWORD@localhost:5432/centralpay

# Public HTTPS base URL of this bridge, used to build the CentralPay return URL
PUBLIC_BASE_URL=https://pay.example.com

# API key the Telegram bot must send in POST /api/custom-payment (generate a long random value)
INBOUND_API_KEY=CHANGE_ME_GENERATED_INBOUND_API_KEY

# Secret used to HMAC-sign callback URLs (generate a long random value)
CALLBACK_HMAC_SECRET=CHANGE_ME_GENERATED_CALLBACK_HMAC_SECRET

# CentralPay web service. The gateway issues a SINGLE API key that
# authenticates both getLink and verify: put the same value in both
# variables (they stay separate so a future split key needs no change).
CENTRALPAY_BASE_URL=https://centralapi.org/webservice/basic
CENTRALPAY_GETLINK_API_KEY=CHANGE_ME_CENTRALPAY_API_KEY
CENTRALPAY_VERIFY_API_KEY=CHANGE_ME_CENTRALPAY_API_KEY

# LEGACY shared gateway payer id. No longer used to create new payments (each
# payment now derives a per-customer gateway userId); kept for compatibility
# and to interpret historical payments.
CENTRALPAY_USER_ID=1

# Dedicated secret for deriving a STABLE per-customer gateway payer identity
# so CentralPay saved-card suggestions can never be shared across customers
# (incident 2026-07). MUST be unique — never reuse another secret. Required for
# payment creation; empty fails closed. Generate e.g. `openssl rand -hex 32`.
CENTRALPAY_PAYER_ID_SECRET=CHANGE_ME_DEDICATED_PAYER_ID_SECRET

# Emergency privacy containment: set false to immediately stop issuing new
# payment links (callback verification of in-flight payments is unaffected).
PAYMENT_CREATION_ENABLED=true

# Timeout in seconds for outbound CentralPay HTTP calls
CENTRALPAY_TIMEOUT_SECONDS=15

# json (production default) or text (development)
LOG_FORMAT=json

# Payment amount bounds in TOMAN
MIN_PAYMENT_AMOUNT_TOMAN=1000
MAX_PAYMENT_AMOUNT_TOMAN=100000000

# Optional: shown as a "return to bot" link on payer-facing pages
TELEGRAM_BOT_USERNAME=

# --- Application-level rate limiting (per API process, in-memory) ---
RATE_LIMIT_ENABLED=true
# Authenticated POST /api/custom-payment requests per minute
RATE_LIMIT_CREATE_PER_MINUTE=120
# Invalid inbound API keys tolerated per 10 minutes before 429
RATE_LIMIT_INVALID_KEY_PER_10MIN=20
# Invalid callback signatures tolerated per 10 minutes before 429
RATE_LIMIT_INVALID_SIGNATURE_PER_10MIN=100

# Emit a one-time critical admin alert + audit event when the FIRST
# gateway-verified payment is recorded (production go-live guard).
FIRST_PAYMENT_GUARD_ENABLED=false

# --- Administrator Telegram bot (optional; disabled by default) ---
ADMIN_BOT_ENABLED=false
ADMIN_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs (never usernames)
ADMIN_TELEGRAM_IDS=
ADMIN_BOT_ALERTS_ENABLED=true
ADMIN_BOT_PAYMENT_SUCCESS_ALERTS=false
ADMIN_BOT_ERROR_ALERTS=true
ADMIN_BOT_MANUAL_REVIEW_ALERTS=true
ADMIN_BOT_BACKUP_ALERTS=true
ADMIN_BOT_HEALTH_ALERTS=true
ADMIN_BOT_DAILY_REPORT_ENABLED=true
ADMIN_BOT_DAILY_REPORT_TIME=09:00
ADMIN_BOT_TIMEZONE=Asia/Tehran
ADMIN_BOT_MAX_MESSAGE_LENGTH=3500
ADMIN_BOT_ALERT_DEDUP_MINUTES=30

# --- Bot notification (Phase 2) ---

# Complete bot payment endpoint, e.g. https://bot.example.com/api/payment
BOT_PAYMENT_NOTIFY_URL=https://bot.example.com/api/payment

# Token sent in the Token header (the bot /token2 value)
BOT_NOTIFY_TOKEN=CHANGE_ME_BOT_TOKEN

# safe (default): never auto-retry ambiguous deliveries; they go to manual
# review. idempotent: ONLY when the bot developer has explicitly confirmed
# duplicate order_id delivery is idempotent.
BOT_NOTIFY_RETRY_MODE=safe

# Delivery attempt limit before manual review (reason: retry_limit_reached)
BOT_NOTIFY_MAX_ATTEMPTS=6

BOT_NOTIFY_CONNECT_TIMEOUT_SECONDS=5
BOT_NOTIFY_READ_TIMEOUT_SECONDS=15

# Worker poll interval
BOT_NOTIFY_WORKER_INTERVAL_SECONDS=10

# Claims older than this are treated as an interrupted (ambiguous) attempt.
# Must exceed connect + read timeouts.
BOT_NOTIFY_CLAIM_TIMEOUT_SECONDS=120

# --- Server-side payment reconciliation (worker) -----------------------------
# Recovers payments stuck in link_created because the payer completed payment
# but the browser callback never reached the API. Uses the SAME verification
# and settlement path as the callback (all financial checks identical); the
# callback stays the fast primary path. Set RECONCILIATION_ENABLED=false to
# stop the polling instantly (callbacks are unaffected).
RECONCILIATION_ENABLED=true
# Give the normal browser callback this long before the first server check.
RECONCILIATION_MIN_AGE_SECONDS=30
# How often the DEDICATED reconciliation thread runs a pass. Reconciliation
# never runs inline in the notification loop, so bot notification delivery
# keeps its cadence even when a CentralPay verify call is slow or times out.
RECONCILIATION_INTERVAL_SECONDS=10
# Payments per pass. BATCH_SIZE / INTERVAL is an AVERAGE upper bound on
# gateway verify calls (defaults: <= 1/s) — a pass may burst its whole batch
# back-to-back before waiting out the interval. Real load is far lower
# because retries back off exponentially.
RECONCILIATION_BATCH_SIZE=10
# Per-payment retry budget with bounded exponential backoff:
# INITIAL * 2^(attempt-1), capped at MAX_BACKOFF (defaults: 20s .. 15min;
# 60 attempts spread over roughly 12 hours). Exhausted payments stay in
# link_created for operators — never auto-failed, never auto-paid.
RECONCILIATION_MAX_ATTEMPTS=60
RECONCILIATION_INITIAL_BACKOFF_SECONDS=20
RECONCILIATION_MAX_BACKOFF_SECONDS=900
