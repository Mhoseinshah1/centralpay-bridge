#!/usr/bin/env bash
# CentralPay Bridge management command. Installed to /usr/local/bin/centralpay.
# Never prints API keys, tokens, database passwords, callback secrets, or the
# full environment file.

set -Eeuo pipefail

INSTALL_DIR="${CENTRALPAY_INSTALL_DIR:-/opt/centralpay-bridge}"
CONFIG_DIR="${CENTRALPAY_CONFIG_DIR:-/etc/centralpay-bridge}"
BACKUP_DIR="${CENTRALPAY_BACKUP_DIR:-/var/backups/centralpay-bridge}"
ENV_FILE="${CONFIG_DIR}/centralpay.env"
CREDENTIALS_FILE="${CONFIG_DIR}/credentials.txt"

log()  { printf '\033[1;32m[centralpay]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[centralpay] WARNING:\033[0m %s\n' "$*" >&2; }
fail() { printf '\033[1;31m[centralpay] ERROR:\033[0m %s\n' "$*" >&2; exit 1; }

trap 'printf "\033[1;31m[centralpay] Command failed.\033[0m\n" >&2' ERR

usage() {
    cat <<'EOF'
Usage: centralpay COMMAND [ARGS]

Service:
  status                 Overall health and state summary
  logs [COMPONENT]       Recent + live logs (api|worker|db|caddy)
  logs-errors [COMPONENT] Warning/error events only
  restart | stop | start Service lifecycle
  version                Application and stack versions

Deployment:
  update --check         Show installed vs available version
  update                 Verify release checksum, backup, deploy, migrate, restart
  rollback               Roll application files back to the previous version
  migrate [SUB]          Run migrations (SUB: upgrade|current|history; default upgrade)
  ssl                    Re-check DNS and retry TLS certificate issuance

Manual review (host-only; never changes financial records):
  review list [--all]    Unresolved manual-review payments
  review show ORDER_ID   Full review detail
  review acknowledge ORDER_ID --note TEXT
  review resolve ORDER_ID --resolution VALUE --note TEXT
  review resend ORDER_ID --confirm-idempotent-bot --yes   (idempotent mode only)

Data:
  backup                 Create a validated PostgreSQL backup now
  backups                List backups with validation state
  restore FILE [--yes]   Restore a backup (asks for confirmation)
  db-check [--repair-sequences]  Database integrity checks (read-only by default)

Service fee (changes apply to NEW orders only; history is permanent):
  fee status             Current fee, policy ID, and next scheduled change
  fee set RATE --note TEXT          Set the fee now (e.g. RATE=10 or 7.5)
  fee schedule RATE --at ISO --note TEXT   Schedule a future fee change
  fee history            Full append-only policy history
  fee cancel POLICY_ID --note TEXT  Cancel a scheduled policy (kept in history)

Inspection:
  diagnose               Full system diagnosis (no secrets printed)
  payment ORDER_ID       One payment with its audit history
  recent                 Most recent payments
  retry-queue            Payments awaiting bot notification
  manual-review          Payments requiring administrator review
  credentials            Show the installation summary (root only)

Administrator Telegram bot:
  admin-bot status       Admin bot container state and configuration state
  admin-bot logs         Admin bot logs
  admin-bot restart      Restart the admin bot service
  admin-bot enable       Validate configuration and start the admin bot
  admin-bot disable      Stop the admin bot (configuration preserved)
  admin-bot test-alert   Queue a clearly marked test message to administrators

Removal:
  uninstall              Remove services (data and backups preserved by default)
EOF
}

require_root() {
    [[ "$(id -u)" -eq 0 ]] || fail "This command requires root. Use: sudo centralpay $*"
}

require_install() {
    [[ -f "${INSTALL_DIR}/docker-compose.yml" ]] \
        || fail "No installation found in ${INSTALL_DIR}. Run the installer first."
}

compose() {
    # The admin-bot service lives behind a Compose profile keyed off the
    # single source of truth in the config env file.
    local -a profile_args=()
    if grep -qE '^ADMIN_BOT_ENABLED=true$' "$ENV_FILE" 2>/dev/null; then
        profile_args=(--profile admin-bot)
    fi
    docker compose --project-directory "$INSTALL_DIR" "${profile_args[@]}" "$@"
}

env_value() {
    # $1 = variable name; reads the config env file without exposing others.
    grep -E "^$1=" "$ENV_FILE" 2>/dev/null | head -1 | cut -d= -f2- || true
}

payment_domain() {
    env_value PUBLIC_BASE_URL | sed -E 's#^https?://##'
}

psql_count() {
    # $1 = SQL; prints a number or "n/a".
    compose exec -T db psql -U centralpay -d centralpay -tAc "$1" 2>/dev/null | tr -d '[:space:]' || echo "n/a"
}

app_version() {
    grep -E '^APP_VERSION' "${INSTALL_DIR}/app/version.py" 2>/dev/null \
        | sed -E 's/.*"(.*)".*/\1/' || echo "unknown"
}

# ---------------------------------------------------------------------------

cmd_status() {
    require_install
    local domain
    domain=$(payment_domain)
    echo "CentralPay Bridge status"
    echo "========================"
    echo
    echo "-- Containers --"
    compose ps 2>/dev/null || warn "Cannot query containers (is Docker running?)"
    echo
    echo "-- Health --"
    for svc in api worker db caddy; do
        local cid state health
        cid=$(compose ps -q "$svc" 2>/dev/null || true)
        if [[ -n "$cid" ]]; then
            state=$(docker inspect -f '{{.State.Status}}' "$cid" 2>/dev/null || echo unknown)
            health=$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}n/a{{end}}' "$cid" 2>/dev/null || echo n/a)
            printf '  %-8s state=%s health=%s\n' "$svc" "$state" "$health"
        else
            printf '  %-8s not running\n' "$svc"
        fi
    done
    echo
    echo "-- Public health --"
    if [[ -n "$domain" ]]; then
        local code
        code=$(curl -sS --max-time 10 -o /dev/null -w '%{http_code}' "https://${domain}/health/ready" 2>/dev/null || echo "000")
        echo "  https://${domain}/health/ready -> HTTP ${code}"
        if [[ "$code" == "200" ]]; then
            echo "  TLS: active"
        else
            echo "  TLS: not confirmed (DNS pending, certificate pending, or service down)"
        fi
    else
        echo "  (domain unknown — configuration unreadable)"
    fi
    echo
    echo "-- Queues --"
    echo "  pending notifications: $(psql_count "SELECT count(*) FROM payments WHERE status='bot_notify_pending'")"
    echo "  manual review:         $(psql_count "SELECT count(*) FROM payments WHERE status='manual_review'")"
    echo
    echo "-- Backups --"
    local last_backup
    last_backup=$(find "$BACKUP_DIR" -name '*.dump' -type f -printf '%T@ %p\n' 2>/dev/null \
        | sort -rn | head -1 | cut -d' ' -f2- || true)
    if [[ -n "$last_backup" ]]; then
        echo "  last backup: ${last_backup} ($(date -u -r "$last_backup" +%Y-%m-%dT%H:%M:%SZ))"
    else
        echo "  last backup: none found in ${BACKUP_DIR}"
    fi
    echo
    echo "-- System --"
    echo "  disk: $(df -h / | awk 'NR==2 {print $4 " free of " $2 " (" $5 " used)"}')"
    echo "  docker compose: $(docker compose version --short 2>/dev/null || echo unavailable)"
    echo "  application: $(app_version)"
}

validate_component() {
    # Allowlist (audit): log commands accept only known service names —
    # never arbitrary Compose service names or option-like values.
    case "$1" in
        api|worker|db|caddy|admin-bot|migrate) return 0 ;;
        *) fail "Unknown component: $1 (use api|worker|db|caddy|admin-bot|migrate)" ;;
    esac
}

cmd_logs() {
    require_install
    local svc="${1:-}"
    if [[ -n "$svc" ]]; then
        validate_component "$svc"
        compose logs --tail 200 -f "$svc"
    else
        compose logs --tail 100 -f
    fi
}

cmd_logs_errors() {
    require_install
    local svc="${1:-}"
    local -a target=()
    if [[ -n "$svc" ]]; then
        validate_component "$svc"
        target=("$svc")
    fi
    # Structured JSON logs carry "level"; plain logs are matched by keyword.
    compose logs --tail 1000 "${target[@]}" 2>&1 \
        | grep -Ei '"level": ?"(warning|error|critical)"|\b(error|warning|critical|fatal)\b' \
        || echo "No warning or error events in the recent logs."
}

cmd_migrate() {
    require_root migrate
    require_install
    local sub="${1:-upgrade}"
    case "$sub" in
        upgrade) compose run --rm migrate alembic upgrade head ;;
        current) compose run --rm migrate alembic current ;;
        history) compose run --rm migrate alembic history ;;
        *) fail "Unknown migrate subcommand: ${sub} (use upgrade|current|history)" ;;
    esac
}

VERSION_HISTORY_FILE="${CONFIG_DIR}/version_history"
REPO_SLUG="Mhoseinshah1/centralpay-bridge"

record_version_history() {
    # $1 = new sha; keeps current and previous for rollback.
    local new_sha="$1" current_sha=""
    [[ -f "$VERSION_HISTORY_FILE" ]] \
        && current_sha=$(grep -E '^current=' "$VERSION_HISTORY_FILE" | cut -d= -f2- || true)
    umask 077
    {
        echo "current=${new_sha}"
        echo "previous=${current_sha}"
        echo "updated_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    } > "$VERSION_HISTORY_FILE"
    chmod 600 "$VERSION_HISTORY_FILE"
}

verify_release_artifact() {
    # $1 = release tag. Downloads the release artifact and SHA256SUMS and
    # verifies the checksum as an integrity gate before deploying the tag.
    local tag="$1" tmp
    tmp=$(mktemp -d)
    local base="https://github.com/${REPO_SLUG}/releases/download/${tag}"
    local artifact="centralpay-bridge-${tag#v}.tar.gz"
    log "Verifying release artifact checksum for ${tag}..."
    if ! curl -fsSL -o "${tmp}/${artifact}" "${base}/${artifact}" \
        || ! curl -fsSL -o "${tmp}/SHA256SUMS" "${base}/SHA256SUMS"; then
        rm -rf "$tmp"
        if grep -qE '^CENTRALPAY_UPDATE_ALLOW_UNVERIFIED=true$' "$ENV_FILE" 2>/dev/null; then
            warn "Release artifact/SHA256SUMS not downloadable; continuing UNVERIFIED (CENTRALPAY_UPDATE_ALLOW_UNVERIFIED=true)."
            return 0
        fi
        fail "Cannot download the release artifact and SHA256SUMS for ${tag}. Publish the GitHub release first, or set CENTRALPAY_UPDATE_ALLOW_UNVERIFIED=true (not recommended)."
    fi
    if (cd "$tmp" && grep " ${artifact}\$" SHA256SUMS | sha256sum -c --quiet); then
        log "Checksum verified: ${artifact}"
        rm -rf "$tmp"
        return 0
    fi
    rm -rf "$tmp"
    fail "CHECKSUM MISMATCH for ${artifact}. Aborting update."
}

cmd_update_check() {
    require_install
    local ref current remote
    ref=$(env_value CENTRALPAY_UPDATE_REF); ref="${ref:-main}"
    current=$(git -C "$INSTALL_DIR" rev-parse HEAD)
    git -C "$INSTALL_DIR" fetch --tags origin "$ref" >/dev/null 2>&1 \
        || fail "Cannot fetch ${ref} from origin."
    remote=$(git -C "$INSTALL_DIR" rev-parse FETCH_HEAD)
    echo "configured ref:  ${ref}"
    echo "installed:       ${current}"
    echo "available:       ${remote}"
    if [[ "$current" == "$remote" ]]; then
        echo "status:          up to date"
    else
        echo "status:          update available (run: centralpay update)"
    fi
}

cmd_update() {
    require_root update
    require_install
    local ref previous
    ref=$(env_value CENTRALPAY_UPDATE_REF)
    ref="${ref:-main}"
    previous=$(git -C "$INSTALL_DIR" rev-parse HEAD)
    if [[ "$ref" =~ ^v?[0-9]+\.[0-9]+\.[0-9]+ ]]; then
        verify_release_artifact "$ref"
    else
        warn "Update ref '${ref}' is not a release tag (DEVELOPMENT MODE, no artifact checksum). Pin CENTRALPAY_UPDATE_REF to a release tag for production."
    fi
    log "Creating pre-update backup..."
    "${INSTALL_DIR}/scripts/backup.sh" || fail "Pre-update backup failed; update aborted."
    log "Fetching ${ref}..."
    git -C "$INSTALL_DIR" fetch --tags origin "$ref"
    git -C "$INSTALL_DIR" checkout -q FETCH_HEAD
    record_version_history "$(git -C "$INSTALL_DIR" rev-parse HEAD)"
    log "Building images..."
    compose build --quiet
    log "Applying migrations and restarting services (configuration in ${CONFIG_DIR} is preserved)..."
    if compose up -d --wait; then
        log "Update complete: $(git -C "$INSTALL_DIR" rev-parse --short HEAD) (was ${previous:0:7})"
        cmd_status || true
    else
        warn "Health checks FAILED after update."
        warn "Application rollback: centralpay rollback"
        warn "Database schema is NOT downgraded automatically (migrations are"
        warn "forward-only; see MIGRATION_GUIDE.md). If the schema changed,"
        warn "restore the pre-update backup: centralpay backups && centralpay restore FILE"
        exit 1
    fi
}

cmd_rollback() {
    require_root rollback
    require_install
    local previous
    previous=$(grep -E '^previous=' "$VERSION_HISTORY_FILE" 2>/dev/null | cut -d= -f2- || true)
    [[ -n "$previous" ]] || fail "No previous version recorded in ${VERSION_HISTORY_FILE}."
    echo "This rolls back APPLICATION FILES to ${previous:0:12}."
    echo "The database schema is never downgraded automatically (forward-only"
    echo "migrations); if the newer schema is incompatible, restore a backup."
    local answer
    read -r -p "Type ROLLBACK to continue: " answer < /dev/tty
    [[ "$answer" == "ROLLBACK" ]] || fail "Rollback cancelled."
    log "Creating pre-rollback backup..."
    "${INSTALL_DIR}/scripts/backup.sh" || fail "Pre-rollback backup failed; aborted."
    git -C "$INSTALL_DIR" checkout -q "$previous" \
        || fail "Cannot check out ${previous}."
    record_version_history "$previous"
    compose build --quiet
    if compose up -d --wait; then
        log "Rollback complete: now at ${previous:0:12}."
    else
        warn "Health checks failed after rollback; inspect: centralpay diagnose"
        exit 1
    fi
}

cmd_review() {
    require_root review
    require_install
    local sub="${1:-list}"
    shift || true
    case "$sub" in
        list|show)
            compose exec -T api python -m app.ops review "$sub" "$@"
            ;;
        acknowledge)
            compose exec -T api python -m app.ops review acknowledge "$@"
            ;;
        resolve)
            echo "Resolving marks the payment's operational review complete."
            echo "It never changes amounts, verification facts, or customer balances."
            local answer
            read -r -p "Type RESOLVE to continue: " answer < /dev/tty
            [[ "$answer" == "RESOLVE" ]] || fail "Cancelled."
            compose exec -T api python -m app.ops review resolve "$@"
            ;;
        resend)
            compose exec -T api python -m app.ops review resend "$@"
            ;;
        *)
            fail "Unknown review subcommand: ${sub} (list|show|acknowledge|resolve|resend)"
            ;;
    esac
}

cmd_backup() {
    require_root backup
    require_install
    "${INSTALL_DIR}/scripts/backup.sh"
}

cmd_backups() {
    echo "Backups in ${BACKUP_DIR}:"
    local file
    local found=false
    for file in "${BACKUP_DIR}"/*.dump; do
        [[ -e "$file" ]] || continue
        found=true
        local state="UNVALIDATED"
        if [[ -f "${file}.ok" && -f "${file}.manifest" ]]; then
            state="OK"
        elif [[ -f "${file}.ok" ]]; then
            # Validated at creation but has no checksum manifest: restoring
            # it requires the explicit RESTORE-LEGACY confirmation.
            state="OK-legacy"
        fi
        printf '  %s  %8s  %-9s  %s\n' \
            "$(date -u -r "$file" +%Y-%m-%dT%H:%M:%SZ)" \
            "$(du -h -- "$file" | cut -f1)" \
            "$state" \
            "$file"
    done
    [[ "$found" == "true" ]] || echo "  (none)"
}

restore_failure_instructions() {
    # Printed whenever the database may be partially restored. Services are
    # deliberately left STOPPED — never restart against a half-restored
    # database.
    local file="$1" latest
    latest=$(find "$BACKUP_DIR" -maxdepth 1 -name 'centralpay-*.dump' -type f \
        -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2- || true)
    {
        echo
        echo "restore_failed: the database may be PARTIALLY restored."
        echo "API, worker, and admin bot remain STOPPED on purpose."
        echo
        echo "Recovery steps:"
        echo "  1. The pre-restore backup taken moments ago is the newest file in"
        echo "     ${BACKUP_DIR}:"
        echo "       ${latest:-<none found>}"
        echo "  2. Restore it to return to the pre-restore state:"
        echo "       centralpay restore ${latest:-<pre-restore-backup>}"
        echo "  3. Only after a restore completes successfully will services be"
        echo "     started again. Do NOT run 'centralpay start' before that."
        echo "  4. The input file that failed was preserved: ${file}"
    } >&2
}

cmd_restore() {
    require_root restore
    require_install
    local file="${1:-}" confirm="${2:-}"
    [[ -n "$file" ]] || fail "Usage: centralpay restore FILE [--yes]"
    # Regular files only: symlinks are refused (symlink-swap protection).
    [[ -f "$file" && ! -L "$file" ]] \
        || fail "Backup must be an existing regular file (symlinks are refused): ${file}"
    [[ -s "$file" ]] || fail "Backup file is empty: ${file}"
    [[ "$(head -c 5 -- "$file")" == "PGDMP" ]] \
        || fail "Not a pg_dump custom-format archive (bad magic): ${file}"

    # Exclusive lock shared with scripts/backup.sh: no concurrent backup,
    # no concurrent restore. Held for the whole restore; the pre-restore
    # backup inherits it via CENTRALPAY_BACKUP_LOCK_HELD.
    mkdir -p "$BACKUP_DIR"
    exec 9>"${BACKUP_DIR}/.backup.lock"
    flock -n 9 || fail "Another backup or restore is already running."

    log "restore_validation_started: ${file}"
    compose exec -T db pg_restore --list < "$file" > /dev/null \
        || fail "restore_validation_failed: not a valid pg_dump custom-format backup."

    local manifest="${file}.manifest"
    if [[ -f "$manifest" && ! -L "$manifest" ]]; then
        local expected actual
        expected=$(grep -E '^sha256=' -- "$manifest" | head -1 | cut -d= -f2)
        [[ -n "$expected" ]] || fail "Manifest has no sha256 entry: ${manifest}"
        actual=$(sha256sum -- "$file" | cut -d' ' -f1)
        [[ "$actual" == "$expected" ]] \
            || fail "restore_validation_failed: sha256 mismatch — the backup is corrupted or was tampered with."
        log "Checksum verified (sha256 ${actual:0:12}...)."
    else
        # Legacy file with no integrity proof. --yes bypasses only the
        # interactive confirmation, never this validation gap.
        warn "No manifest/checksum found: LEGACY backup with no integrity proof."
        [[ "$confirm" != "--yes" ]] \
            || fail "--yes cannot accept a legacy backup. Run interactively and type RESTORE-LEGACY."
        local legacy
        read -r -p "Type RESTORE-LEGACY to accept the unverified file: " legacy < /dev/tty
        [[ "$legacy" == "RESTORE-LEGACY" ]] || fail "Restore cancelled."
    fi

    if [[ "$confirm" != "--yes" ]]; then
        echo "This will REPLACE the current database with: ${file}"
        echo "A pre-restore backup will be created first."
        local answer
        read -r -p "Type RESTORE to continue: " answer < /dev/tty
        [[ "$answer" == "RESTORE" ]] || fail "Restore cancelled."
    fi

    log "pre_restore_backup_started"
    CENTRALPAY_BACKUP_LOCK_HELD=1 "${INSTALL_DIR}/scripts/backup.sh" \
        || fail "Pre-restore backup failed; restore aborted (database untouched)."
    log "pre_restore_backup_completed"

    log "Stopping API, worker, and admin bot..."
    compose stop api worker
    if grep -qE '^ADMIN_BOT_ENABLED=true$' "$ENV_FILE" 2>/dev/null; then
        compose stop admin-bot
    fi

    log "restore_started: ${file}"
    compose exec -T db psql -U centralpay -d postgres -c \
        "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname='centralpay' AND pid <> pg_backend_pid();" >/dev/null
    compose exec -T db psql -U centralpay -d postgres -c "DROP DATABASE IF EXISTS centralpay;" >/dev/null
    compose exec -T db psql -U centralpay -d postgres -c "CREATE DATABASE centralpay OWNER centralpay;" >/dev/null
    if ! compose exec -T db pg_restore -U centralpay -d centralpay --no-owner \
        --role=centralpay --exit-on-error < "$file"; then
        restore_failure_instructions "$file"
        exit 1
    fi

    log "Running migrations..."
    if ! compose run --rm migrate alembic upgrade head; then
        restore_failure_instructions "$file"
        exit 1
    fi

    log "Verifying database integrity (db-check + sequence repair)..."
    if ! compose run --rm migrate python -m app.ops db-check --repair-sequences; then
        printf '[centralpay] ERROR: post_restore_integrity_failed\n' >&2
        restore_failure_instructions "$file"
        exit 1
    fi

    log "Restarting services..."
    compose up -d --wait || fail "Services failed health checks after restore."
    logger -t centralpay "database restore completed from ${file}" 2>/dev/null || true
    log "restore_completed: ${file} (the supplied backup file was preserved)"
}

cmd_db_check() {
    require_install
    # Read-only integrity checks (constraints, orphans, statuses, claim
    # anomalies, fee snapshots, sequence positions). --repair-sequences
    # additionally advances any sequence that fell behind its table maximum.
    compose run --rm migrate python -m app.ops db-check "$@"
}

cmd_fee() {
    require_install
    local sub="${1:-status}"
    shift || true
    case "$sub" in
        status|history)
            compose run --rm migrate python -m app.ops fee "$sub"
            ;;
        set|schedule|cancel)
            # Mutations are root-only, delegated to the typed Python
            # operations command (no shell-generated SQL, no env-file
            # mutation). All arguments pass through verbatim as an argv
            # array — never interpolated into a shell string.
            require_root "fee ${sub}"
            compose run --rm migrate python -m app.ops fee "$sub" "$@"
            ;;
        *)
            fail "Unknown fee subcommand: ${sub} (use status|set|schedule|history|cancel)"
            ;;
    esac
}

cmd_diagnose() {
    require_install
    local domain
    domain=$(payment_domain)
    echo "CentralPay Bridge diagnostics (no secrets are printed)"
    echo "======================================================"
    # shellcheck disable=SC1091
    echo "OS:            $(. /etc/os-release 2>/dev/null && echo "${PRETTY_NAME:-unknown}")"
    echo "Architecture:  $(uname -m)"
    echo "Memory:        $(awk '/MemTotal/ {printf "%d MB", $2/1024}' /proc/meminfo)"
    echo "Disk:          $(df -h / | awk 'NR==2 {print $4 " free of " $2}')"
    echo "Docker:        $(docker --version 2>/dev/null || echo unavailable)"
    echo "Compose:       $(docker compose version --short 2>/dev/null || echo unavailable)"
    echo
    echo "-- Containers --"
    compose ps 2>/dev/null || echo "unavailable"
    echo
    echo "-- Database --"
    echo "readiness:     $(compose exec -T db pg_isready -U centralpay -d centralpay 2>/dev/null || echo 'NOT READY')"
    echo "migration:     $(psql_count "SELECT version_num FROM alembic_version")"
    echo "pending queue: $(psql_count "SELECT count(*) FROM payments WHERE status='bot_notify_pending'")"
    echo "manual review: $(psql_count "SELECT count(*) FROM payments WHERE status='manual_review'")"
    echo
    echo "-- API --"
    echo "local ready:   $(compose exec -T api curl -fsS --max-time 5 http://127.0.0.1:8000/health/ready 2>/dev/null || echo 'NOT READY')"
    if [[ -n "$domain" ]]; then
        echo "public ready:  HTTP $(curl -sS --max-time 10 -o /dev/null -w '%{http_code}' "https://${domain}/health/ready" 2>/dev/null || echo 000)"
        echo
        echo "-- Network --"
        echo "DNS:           ${domain} -> $(getent ahostsv4 "$domain" 2>/dev/null | awk 'NR==1 {print $1}' || echo 'does not resolve')"
        echo "port 80:       $(ss -ltnH 'sport = :80' | head -1 | awk '{print $4}' || echo 'not listening')"
        echo "port 443:      $(ss -ltnH 'sport = :443' | head -1 | awk '{print $4}' || echo 'not listening')"
        echo "TLS cert:      $(echo | openssl s_client -servername "$domain" -connect "${domain}:443" 2>/dev/null | openssl x509 -noout -enddate 2>/dev/null || echo 'no certificate')"
        echo "CentralPay:    $(curl -sS --max-time 10 -o /dev/null -w 'HTTP %{http_code}' https://centralapi.org 2>/dev/null || echo unreachable)"
        local bot_url bot_host
        bot_url=$(env_value BOT_PAYMENT_NOTIFY_URL)
        if [[ -n "$bot_url" ]]; then
            bot_host=$(echo "$bot_url" | sed -E 's#^https?://([^/:]+).*#\1#')
            echo "Bot API host:  ${bot_host} -> $(curl -sS --max-time 10 -o /dev/null -w 'HTTP %{http_code}' "https://${bot_host}" 2>/dev/null || echo unreachable)"
        fi
    fi
    echo
    echo "-- Backups --"
    cmd_backups
    echo
    echo "-- Recent errors (last 200 lines) --"
    compose logs --tail 200 2>&1 \
        | grep -Ei '"level": ?"(error|critical)"' \
        | tail -20 || echo "none"
}

cmd_ssl() {
    require_root ssl
    require_install
    local domain
    domain=$(payment_domain)
    [[ -n "$domain" ]] || fail "Cannot determine the payment domain from configuration."
    log "Checking DNS for ${domain}..."
    local server_ip domain_ip
    server_ip=$(curl -fsS --max-time 10 https://checkip.amazonaws.com 2>/dev/null | tr -d '[:space:]' || true)
    domain_ip=$(getent ahostsv4 "$domain" 2>/dev/null | awk 'NR==1 {print $1}' || true)
    if [[ -z "$domain_ip" ]]; then
        fail "DNS for ${domain} does not resolve yet. Point it to ${server_ip:-this server} and retry."
    fi
    if [[ -n "$server_ip" && "$domain_ip" != "$server_ip" ]]; then
        warn "DNS resolves to ${domain_ip} but this server appears to be ${server_ip}. Certificates may fail."
    fi
    log "Restarting Caddy to retry certificate issuance..."
    compose restart caddy
    sleep 5
    local code
    code=$(curl -sS --max-time 20 -o /dev/null -w '%{http_code}' "https://${domain}/health/live" 2>/dev/null || echo "000")
    if [[ "$code" == "200" ]]; then
        log "HTTPS is active: https://${domain}/health/live"
    else
        warn "HTTPS not confirmed yet (HTTP ${code}). Certificate issuance can take a minute; check: centralpay logs caddy"
    fi
}

cmd_app_cli() {
    require_install
    compose exec -T api python -m app.cli "$@"
}

cmd_credentials() {
    require_root credentials
    [[ -f "$CREDENTIALS_FILE" ]] || fail "No credentials file at ${CREDENTIALS_FILE}."
    cat "$CREDENTIALS_FILE"
}

cmd_version() {
    echo "application: $(app_version)"
    if [[ -d "${INSTALL_DIR}/.git" ]]; then
        echo "git:         $(git -C "$INSTALL_DIR" rev-parse --short HEAD 2>/dev/null || echo unknown)"
    fi
    echo "compose:     $(docker compose version --short 2>/dev/null || echo unavailable)"
    echo "docker:      $(docker --version 2>/dev/null || echo unavailable)"
}

cmd_admin_bot() {
    local sub="${1:-status}"
    shift || true
    case "$sub" in
        status)
            require_install
            local enabled="disabled"
            grep -qE '^ADMIN_BOT_ENABLED=true$' "$ENV_FILE" 2>/dev/null && enabled="enabled"
            echo "configuration: ${enabled}"
            local ids
            ids=$(env_value ADMIN_TELEGRAM_IDS)
            if [[ -n "$ids" ]]; then
                echo "administrators: $(echo "$ids" | tr ',' '\n' | grep -c .) configured"
            else
                echo "administrators: none configured"
            fi
            local cid
            cid=$(compose ps -q admin-bot 2>/dev/null || true)
            if [[ -n "$cid" ]]; then
                echo "container: $(docker inspect -f '{{.State.Status}} (health: {{if .State.Health}}{{.State.Health.Status}}{{else}}n/a{{end}})' "$cid")"
            else
                echo "container: not running"
            fi
            ;;
        logs)
            require_install
            compose logs --tail 200 -f admin-bot
            ;;
        restart)
            require_root admin-bot restart
            require_install
            compose restart admin-bot
            ;;
        enable)
            require_root admin-bot enable
            require_install
            # Validate presence without ever printing the token value.
            [[ -n "$(env_value ADMIN_BOT_TOKEN)" ]] \
                || fail "ADMIN_BOT_TOKEN is empty in ${ENV_FILE}. Add the BotFather token first."
            local ids
            ids=$(env_value ADMIN_TELEGRAM_IDS)
            [[ "$ids" =~ ^[0-9]+(,[0-9]+)*$ ]] \
                || fail "ADMIN_TELEGRAM_IDS must be comma-separated numeric Telegram user IDs."
            sed -i 's/^ADMIN_BOT_ENABLED=.*/ADMIN_BOT_ENABLED=true/' "$ENV_FILE"
            compose up -d --wait admin-bot
            log "Admin bot enabled and started."
            ;;
        disable)
            require_root admin-bot disable
            require_install
            # Stop the service; configuration (including the token) is
            # preserved unless the administrator edits the env file.
            compose --profile admin-bot stop admin-bot 2>/dev/null || true
            sed -i 's/^ADMIN_BOT_ENABLED=.*/ADMIN_BOT_ENABLED=false/' "$ENV_FILE"
            log "Admin bot disabled. Configuration preserved in ${ENV_FILE}."
            ;;
        test-alert)
            require_root admin-bot test-alert
            require_install
            grep -qE '^ADMIN_BOT_ENABLED=true$' "$ENV_FILE" 2>/dev/null \
                || fail "Admin bot is disabled. Enable it first: centralpay admin-bot enable"
            compose exec -T api python -m app.ops test-alert
            ;;
        *)
            fail "Unknown admin-bot subcommand: ${sub} (status|logs|restart|enable|disable|test-alert)"
            ;;
    esac
}

cmd_uninstall() {
    require_root uninstall
    require_install
    echo "This stops and removes the CentralPay Bridge containers."
    echo "By default it PRESERVES: the PostgreSQL data volume, backups, and credentials."
    local answer
    read -r -p "Type UNINSTALL to continue: " answer < /dev/tty
    [[ "$answer" == "UNINSTALL" ]] || fail "Uninstall cancelled."

    systemctl disable --now centralpay-backup.timer 2>/dev/null || true
    rm -f /etc/systemd/system/centralpay-backup.service /etc/systemd/system/centralpay-backup.timer
    systemctl daemon-reload 2>/dev/null || true

    compose down

    read -r -p "ALSO DELETE the PostgreSQL data volume (ALL PAYMENT RECORDS)? Type DELETE-DATA to confirm, anything else to keep: " answer < /dev/tty
    if [[ "$answer" == "DELETE-DATA" ]]; then
        compose down -v
        warn "PostgreSQL data volume deleted."
    else
        log "PostgreSQL data volume preserved."
    fi

    read -r -p "ALSO DELETE backups in ${BACKUP_DIR}? Type DELETE-BACKUPS to confirm, anything else to keep: " answer < /dev/tty
    if [[ "$answer" == "DELETE-BACKUPS" ]]; then
        rm -rf "$BACKUP_DIR"
        warn "Backups deleted."
    else
        log "Backups preserved in ${BACKUP_DIR}."
    fi

    log "Configuration and credentials preserved in ${CONFIG_DIR}."
    read -r -p "Remove the 'centralpay' command itself? [y/N]: " answer < /dev/tty
    if [[ "$answer" =~ ^[Yy] ]]; then
        rm -f /usr/local/bin/centralpay
        log "Management command removed."
    fi
    log "Uninstall finished."
}

# ---------------------------------------------------------------------------

main() {
    local cmd="${1:-}"
    shift || true
    case "$cmd" in
        status)        cmd_status "$@" ;;
        logs)          cmd_logs "$@" ;;
        logs-errors)   cmd_logs_errors "$@" ;;
        restart)       require_root restart; require_install; compose restart ;;
        stop)          require_root stop; require_install; compose stop ;;
        start)         require_root start; require_install; compose up -d --wait ;;
        update)
            if [[ "${1:-}" == "--check" ]]; then
                cmd_update_check
            else
                cmd_update "$@"
            fi
            ;;
        rollback)      cmd_rollback "$@" ;;
        review)        cmd_review "$@" ;;
        migrate)       cmd_migrate "$@" ;;
        backup)        cmd_backup "$@" ;;
        backups)       cmd_backups "$@" ;;
        restore)       cmd_restore "$@" ;;
        db-check)      cmd_db_check "$@" ;;
        fee)           cmd_fee "$@" ;;
        diagnose)      cmd_diagnose "$@" ;;
        payment)       cmd_app_cli payment "$@" ;;
        recent)        cmd_app_cli recent "$@" ;;
        retry-queue)   cmd_app_cli retry-queue "$@" ;;
        manual-review) cmd_app_cli manual-review "$@" ;;
        credentials)   cmd_credentials "$@" ;;
        admin-bot)     cmd_admin_bot "$@" ;;
        ssl)           cmd_ssl "$@" ;;
        version)       cmd_version "$@" ;;
        uninstall)     cmd_uninstall "$@" ;;
        help|-h|--help|"") usage ;;
        *) usage; fail "Unknown command: ${cmd}" ;;
    esac
}

main "$@"
